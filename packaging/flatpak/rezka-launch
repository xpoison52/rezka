#!/bin/sh
set -eu
_pyver="$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')"
export PYTHONPATH="/app/lib/python${_pyver}/site-packages${PYTHONPATH:+:$PYTHONPATH}"
export QT_QUICK_CONTROLS_STYLE="${QT_QUICK_CONTROLS_STYLE:-Basic}"
cd /app/share/rezka
exec python3 /app/share/rezka/main.py "$@"
